        "peerDependencies": {
          "@tiptap/pm": "^3.0.0"
        }
      }
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.4",
    "typescript": "^5.8",
    "vitest": "^3.1"
  }
}
