{
  "name": "@weiui/react",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./editor": {
      "types": "./dist/editor-entry.d.ts",
      "import": "./dist/editor-entry.js"
    },
    "./chart": {
      "types": "./dist/chart-entry.d.ts",
      "import": "./dist/chart-entry.js"
    },
    "./data-table": {
      "types": "./dist/data-table-entry.d.ts",
      "import": "./dist/data-table-entry.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/editor-entry.ts src/chart-entry.ts src/data-table-entry.ts --format esm --dts --external react --external react-dom",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19.0",
    "react-dom": "^19.0"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@weiui/css": "workspace:*",
    "@weiui/headless": "workspace:*",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.0",
    "tailwind-variants": "^0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6",
    "@testing-library/react": "^16.3",
    "@testing-library/user-event": "^14.6",
    "@types/react": "^19.1",
    "@types/react-dom": "^19.1",
    "jsdom": "^26.0",
    "react": "^19.1",
    "react-dom": "^19.1",
    "tsup": "^8.4",
    "vitest": "^3.1"
  }
}
