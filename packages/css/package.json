{
  "name": "@weiui/css",
  "version": "0.0.1",
  "description": "WeiUI CSS layer — zero-JavaScript component styles built on design tokens with logical properties, OKLCH colors, and WCAG AAA contrast.",
  "author": "WeiUI Contributors",
  "license": "MIT",
  "homepage": "https://weiui.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaooye/weiui.git",
    "directory": "packages/css"
  },
  "bugs": { "url": "https://github.com/xiaooye/weiui/issues" },
  "keywords": [
    "css",
    "design-system",
    "weiui",
    "tokens",
    "oklch",
    "logical-properties",
    "cascade-layers",
    "wcag-aaa"
  ],
  "exports": {
    ".": "./dist/weiui.css",
    "./weiui.css": "./dist/weiui.css",
    "./reset.css": "./dist/reset.css",
    "./elements/*": "./dist/elements/*"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "postcss src/index.css -o dist/weiui.css && lightningcss --minify dist/weiui.css -o dist/weiui.min.css"
  },
  "devDependencies": {
    "postcss": "^8.5",
    "postcss-cli": "^11.0",
    "postcss-import": "^16.1",
    "postcss-nesting": "^13.0",
    "lightningcss-cli": "^1.29"
  }
}
