{
  "name": "@weiui/tokens",
  "version": "0.0.1",
  "description": "WeiUI design tokens — W3C Design Tokens Community Group JSON source-of-truth exported as CSS custom properties and TypeScript.",
  "author": "WeiUI Contributors",
  "license": "MIT",
  "homepage": "https://weiui.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaooye/weiui.git",
    "directory": "packages/tokens"
  },
  "bugs": { "url": "https://github.com/xiaooye/weiui/issues" },
  "keywords": [
    "design-tokens",
    "tokens",
    "weiui",
    "oklch",
    "w3c",
    "css-custom-properties",
    "design-system"
  ],
  "type": "module",
  "exports": {
    "./tokens.css": "./dist/tokens.css",
    "./tokens.json": "./dist/tokens.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "validate": "tsx scripts/validate.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@weiui/a11y": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19",
    "vitest": "^3.1"
  }
}
